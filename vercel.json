{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "public/**", "use": "@vercel/static" },
    { "src": "api/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/terms.html", "dest": "/public/terms.html" },
    { "src": "/privacy.html", "dest": "/public/privacy.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
